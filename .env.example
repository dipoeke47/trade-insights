# ─── Bring Your Own Credentials (BYOC) ───────────────────────────────
# With NOTHING set here, the app runs in DEMO mode for everyone.
# Set your own credentials locally (in .env.local) to see real data.

# Robinhood Agentic Trading (Phase 2).
# Obtain via OAuth against Robinhood's official agent MCP endpoint:
#   Trading MCP: https://agent.robinhood.com/mcp/trading
# Docs: https://robinhood.com/us/en/support/agentic-trading
ROBINHOOD_ACCESS_TOKEN=
ROBINHOOD_REFRESH_TOKEN=

# Anthropic API key for the agentic copilot (Phase 3).
ANTHROPIC_API_KEY=
